{
  "name": "auto-stories-vscode",
  "displayName": "Auto Stories",
  "description": "Code assist of the Auto Stories framework.",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/aprosail/auto-stories.git",
    "directory": "editors/vscode"
  },
  "type": "module",
  "private": true,
  "engines": {
    "vscode": "^1.88.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "scripts": {
    "format": "prettier --write .",
    "check": "prettier --check . && eslint",
    "build": "vite-node build.ts",
    "package": "vite-node build.ts pack"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.7",
    "@eslint/js": "^9.20.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^22.13.5",
    "@types/vscode": "^1.97.0",
    "@vscode/vsce": "^3.2.2",
    "eslint": "^9.20.1",
    "globals": "^16.0.0",
    "jiti": "^2.4.2",
    "prettier": "^3.5.2",
    "prettier-plugin-sh": "^0.15.0",
    "rollup": "^4.34.8",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "vite-node": "^3.0.7"
  }
}
